{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "3D Visualizer (Dash)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["visualization/simulator_3d.py"],
      "port": 8050
    },
    {
      "name": "Backend (FastAPI / uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
      "port": 8080
    },
    {
      "name": "Redis",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "redis"],
      "port": 6379
    },
    {
      "name": "Dashboard",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "dashboard"],
      "port": 3000
    },
    {
      "name": "vLLM (Qwen2.5-7B, GPU 필요)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "--profile", "full", "up", "vllm"],
      "port": 8000
    },
    {
      "name": "PX4 SITL (Gazebo + ROS2)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "--profile", "simulation", "up", "sitl"],
      "port": 14550
    }
  ]
}
