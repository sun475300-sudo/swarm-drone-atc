{
  "permissions": {
    "allow": [
      "Bash(git ls-tree:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/update-changelog.py\"",
            "timeout": 30,
            "statusMessage": "README 변경 이력 업데이트 중..."
          }
        ]
      }
    ]
  }
}
