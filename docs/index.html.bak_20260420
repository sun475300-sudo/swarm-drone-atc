<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0055AA" />
  <meta name="color-scheme" content="light dark" />

  <!-- Primary SEO -->
  <title>SDACS — 군집드론 공역통제 자동화 시스템 | Swarm Drone Airspace Control System</title>
  <meta name="description" content="SDACS는 APF(인공 포텐셜 필드)와 WebGPU 기반의 군집드론 공역통제 자동화 시스템입니다. 충돌 해결률 97.8%, 90초 선제 예측, 38,400회 Monte Carlo 검증. 목포대학교 캡스톤디자인 프로젝트." />
  <meta name="keywords" content="SDACS, 군집드론, 공역통제, Swarm Drone, Airspace Control, APF, Artificial Potential Field, WebGPU, 캡스톤디자인, 목포대학교, drone swarm, UAV, collision avoidance, Monte Carlo, 자율비행, CBS, Conflict-Based Search, air traffic management, UTM" />
  <meta name="author" content="장선우 (Sunwoo Jang)" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow" />
  <meta name="language" content="Korean" />
  <meta http-equiv="content-language" content="ko-KR" />
  <link rel="canonical" href="https://sun475300-sudo.github.io/swarm-drone-atc/" />
